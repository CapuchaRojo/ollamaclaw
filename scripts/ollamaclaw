#!/usr/bin/env bash
set -euo pipefail

# Ollamaclaw launcher — routes Claude Code through Ollama Cloud.
# Usage: ollamaclaw [--model MODEL] [claude args...]

MODEL="${MODEL:-qwen3.5:397b-cloud}"
HELP_FLAG=false

# Parse args
while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help) HELP_FLAG=true; shift ;;
    --model) MODEL="$2"; shift 2 ;;
    *) break ;;
  esac
done

if [[ "$HELP_FLAG" == "true" ]]; then
  cat <<EOF
Usage: ollamaclaw [--model MODEL] [claude args...]

Launches Claude Code through Ollama Cloud.

Cloud mode (recommended):
  Uses qwen3.5:397b-cloud for full-stack Claude Code workflows.

Options:
  --model MODEL   Cloud model to use (default: qwen3.5:397b-cloud)
  -h, --help      Show this help message

Examples:
  ollamaclaw
  ollamaclaw --model qwen3.5:397b-cloud
  ollamaclaw --help

Note: Local model fallback is experimental. Cloud mode is the recommended
full-stack Claude Code path. Local models may be used via 'ollama run'
for direct coding help, not Claude Code agent workflows.
EOF
  exit 0
fi

# Verify Ollama is available
if ! command -v ollama &>/dev/null; then
  echo "Error: ollama not found. Install Ollama first." >&2
  exit 1
fi

# Verify Claude Code is available
if ! command -v claude &>/dev/null; then
  echo "Error: claude not found. Install Claude Code or add it to PATH." >&2
  echo "Expected WSL install path is usually: $HOME/.local/bin/claude" >&2
  exit 1
fi

# Export Ollama routing env
export ANTHROPIC_AUTH_TOKEN=ollama
export ANTHROPIC_API_KEY=""
export ANTHROPIC_BASE_URL=http://127.0.0.1:11434

exec claude --model "$MODEL" "$@"
